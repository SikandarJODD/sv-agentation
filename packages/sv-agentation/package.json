{
	"name": "sv-agentation",
	"version": "0.2.2",
	"description": "Dev-mode Svelte inspector for annotating elements, text selections, groups, and areas in the browser.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SikandarJODD/sv-agentation.git"
	},
	"homepage": "https://sv-agentation.com",
	"bugs": {
		"url": "https://github.com/SikandarJODD/sv-agentation/issues"
	},
	"type": "module",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"scripts": {
		"prepare": "svelte-kit sync && svelte-package",
		"build": "pnpm run prepare && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"pack:tarball": "pnpm pack --pack-destination ../../.artifacts",
		"prepack": "pnpm run build"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"@lucide/svelte": "^0.577.0",
		"element-source": "^0.0.5"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"publint": "^0.3.17",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4",
		"jsdom": "^26.1.0"
	},
	"keywords": [
		"svelte",
		"inspector",
		"annotations",
		"developer-tools",
		"component-inspector"
	]
}
